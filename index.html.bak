  <footer>
    <div class="footer-inner">
      <div class="footer-links">
        <a href="https://www.linkedin.com/in/prsarahevans" target="_blank">LinkedIn</a>
        <a href="https://x.com/prsarahevans" target="_blank">X</a>
        <a href="https://stan.store/asksarahevans" target="_blank">Stan Store</a>
        <a href="https://github.com/sarahevansai" target="_blank">GitHub</a>
        <a href="https://www.zenmedia.com" target="_blank">Zen Media</a>
        <a href="mailto:sarah@zenmedia.com">Contact</a>
      </div>
      <p>&copy; 2026 Sarah Evans. All rights reserved.</p>
    </div>
  </footer>

  <script>
    // CHAT ENGINE v3 — Gemini-powered, 10-question limit per session
    let msgCount = 0;
    let chatHistory = [];
    const MAX_QUESTIONS = 10;

    const starters = [
      "Your brand has a new homepage. And you didn't build it. It's whatever ChatGPT, Gemini, and Perplexity say about you when someone asks.\n\nI've been calling this The Before Layer. The AI-generated answer people see before they ever click a link or visit your site. It exists whether you're managing it or not.\n\nMost companies haven't even checked. The ones that have are usually shocked.\n\nWhat are you working on? I can get specific if I know your world.",
      "Here's the thing. The companies winning in the AI economy aren't using the most AI tools. They're redesigning their businesses to be AI-native.\n\nThree layers: how you get discovered, how you operate, how you sell. Most people are still in the 'which chatbot should I use?' phase.\n\nWhat's your world?",
    ];

    let currentAudio = null;

    function addMsg(text, type) {
      const m = document.getElementById('chatMessages');
      const w = document.createElement('div');
      w.className = `cmsg ${type}`;
      const b = document.createElement('div');
      b.className = `cbub ${type === 'bot' ? 'bot-b' : 'user-b'}`;
      if (type === 'bot') {
        b.innerHTML = text.replace(/\n/g, '<br>').replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>');
      } else {
        b.textContent = text;
      }
      w.appendChild(b);
      if (type === 'bot') {
        const btn = document.createElement('button');
        btn.className = 'listen-btn';
        btn.innerHTML = '🔊 Listen';
        btn.onclick = () => playTTS(text, btn);
        w.appendChild(btn);
      }
      m.appendChild(w);
      m.scrollTop = m.scrollHeight;
    }

    async function playTTS(text, btn) {
      // Stop any currently playing audio
      if (currentAudio) { currentAudio.pause(); currentAudio = null; }
      // If this button was playing, just stop
      if (btn.classList.contains('playing')) {
        btn.classList.remove('playing');
        btn.innerHTML = '🔊 Listen';
        return;
      }
      // Reset all other buttons
      document.querySelectorAll('.listen-btn.playing').forEach(b => {
        b.classList.remove('playing'); b.innerHTML = '🔊 Listen';
      });
      btn.disabled = true; btn.innerHTML = '⏳ Loading...';
      try {
        const resp = await fetch('/api/tts', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ text })
        });
        if (!resp.ok) throw new Error('TTS failed');
        const blob = await resp.blob();
        const url = URL.createObjectURL(blob);
        currentAudio = new Audio(url);
        btn.disabled = false; btn.classList.add('playing'); btn.innerHTML = '⏸️ Playing...';
        currentAudio.play();
        currentAudio.onended = () => {
          btn.classList.remove('playing'); btn.innerHTML = '🔊 Listen';
          currentAudio = null; URL.revokeObjectURL(url);
        };
      } catch (e) {
        btn.disabled = false; btn.innerHTML = '🔊 Listen';
        console.error('TTS error:', e);
      }
    }

    function showFollowUps() {
      const s = document.getElementById('chatSuggestions');
      s.innerHTML = '';
      if (msgCount >= MAX_QUESTIONS) return;
      const topics = [
        'What is The Before Layer?',
        'How is this different from SEO?',
        'What is agentic commerce?',
        'Tell me about Answer Share™',
        'How is PR changing?',
        'Where do I start?',
        "What's the PRCR framework?",
        "What's the 90-day system?",
        'How long does it take to see results?',
        'Can small companies compete with big brands?',
        'What makes your approach different?',
        'What if AI says something wrong about my brand?',
        'Tell me about Dual Pathway PR',
        'Does this actually work?'
      ];
      const picks = topics.sort(() => Math.random() - 0.5).slice(0, 4);
      picks.forEach(t => {
        const btn = document.createElement('button');
        btn.className = 'chat-sugg';
        btn.textContent = t;
        btn.onclick = () => askQ(t);
        s.appendChild(btn);
      });
    }

    function showTyping() {
      const m = document.getElementById('chatMessages');
      const typing = document.createElement('div');
      typing.className = 'cmsg bot';
      typing.id = 'typing-indicator';
      typing.innerHTML = '<div class="typing-ind"><span></span><span></span><span></span></div>';
      m.appendChild(typing);
      m.scrollTop = m.scrollHeight;
    }

    function hideTyping() {
      const el = document.getElementById('typing-indicator');
      if (el) el.remove();
    }

    function showCounter() {
      const remaining = MAX_QUESTIONS - msgCount;
      let counter = document.getElementById('question-counter');
      if (!counter) {
        counter = document.createElement('div');
        counter.id = 'question-counter';
        counter.style.cssText = 'text-align:center;font-size:0.7rem;color:var(--text-muted);padding:4px 0;';
        const form = document.getElementById('chatForm');
        form.parentNode.insertBefore(counter, form);
      }
      if (remaining <= 3 && remaining > 0) {
        counter.textContent = `${remaining} question${remaining === 1 ? '' : 's'} remaining`;
      } else if (remaining <= 0) {
        counter.textContent = 'Session complete — thanks for chatting!';
        document.getElementById('chatInput').disabled = true;
        document.getElementById('chatInput').placeholder = 'Session complete';
      } else {
        counter.textContent = '';
      }
    }

    async function askQ(text) {
      if (msgCount >= MAX_QUESTIONS) return;
      
      addMsg(text, 'user');
      document.getElementById('chatSuggestions').innerHTML = '';
      
      // Disable input while waiting
      const input = document.getElementById('chatInput');
      input.disabled = true;
      
      showTyping();

      // Add to history
      chatHistory.push({ role: 'user', text: text });

      try {
        const resp = await fetch('/api/chat', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            message: text,
            history: chatHistory.slice(-8),
            questionCount: msgCount
          })
        });

        const data = await resp.json();
        hideTyping();

        if (data.error) {
          addMsg("Something went sideways on my end. Try again in a sec?", 'bot');
        } else {
          msgCount++;
          chatHistory.push({ role: 'model', text: data.reply });
          addMsg(data.reply, 'bot');
          showCounter();
          
          if (!data.limitReached) {
            setTimeout(() => showFollowUps(), 300);
          }
        }
      } catch (err) {
        hideTyping();
        addMsg("Connection hiccup. Give it another shot?", 'bot');
      }

      input.disabled = false;
      input.focus();
    }

    // Initial greeting
    setTimeout(() => {
      const greeting = starters[Math.floor(Math.random() * starters.length)];
      addMsg(greeting, 'bot');
      setTimeout(() => showFollowUps(), 300);
    }, 800);

    document.getElementById('chatForm').addEventListener('submit', function(e) {
      e.preventDefault();
      const input = document.getElementById('chatInput');
      const text = input.value.trim();
      if (!text) return;
      input.value = '';
      askQ(text);
    });
  </script>

</body>
</html>
