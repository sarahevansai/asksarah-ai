  <!-- ═══════════════════════════════════════════ -->
  <section class="cta">
    <h2>Ready to navigate the <span class="gradient-text">AI economy</span>?</h2>
    <p>Ask the twin. Learn the frameworks. Or bring in the team.</p>
    <div class="cta-btns">
      <a href="https://www.zenmedia.com" target="_blank" class="btn-primary">Work With Us</a>
      <a href="https://stan.store/asksarahevans" class="btn-ghost" target="_blank">Browse Trainings</a>
      <a href="#" class="btn-ghost" onclick="window.scrollTo({top:0,behavior:'smooth'});setTimeout(()=>document.querySelector('#chatInput').focus(),600);return false;">Ask My Twin</a>
